struct au::Paradigm
{
	friend struct segment;
	
	  Paradigm(len_t l, str_c b = 0)
  : range(l)
  { 
    scape= reinterpret_cast<len_t>( new x08_t[l] );
    memset(ptr(), 0, l);
  }
	
	 ~Paradigm() 
  {
    delete[] ptr(); 
    hdr_p ndx = nullptr; 
  }
  
	inline 							x08_p ptr()			{ return reinterpret_cast<x08_p >(scape);			}
	inline 							x08_p ptr(len_t x)	{ return reinterpret_cast<x08_p >(scape + x);	}
	template<typename ini_t> inline x08_p ptr(len_t x)	{ return reinterpret_cast<ini_t*>(scape + x);	}
	inline len_t max_len()		{ return range; }
	inline len_t get_len()		{ return range - sizeof(hdr_t) * width; }
	
  any_p to_open(len_t);				// | allocate a memory block 
  any_p re_open(any_p, len_t);// | reallocate a memory block 
  any_p co_open(any_p, len_t);// | resize a memory block
  any_p be_open(len_t, len_t);// | allocate to that address
	
  template <typename ini_t> ini_t* to_open(len_t);
  template <typename ini_t> ini_t* re_open(any_p, len_t);
  template <typename ini_t> ini_t* co_open(any_p, len_t);
	
  template <typename ini_t> ini_t* 		 	provide_type(ini_t); 		// | MARKED: as deprecated
  template <typename ini_t> vec_t<ini_t> 	provide_list(len_t);		// | this provide a build in vector 
  template <typename ini_t> ini_t&			provide_plan(any_p, any_p); // | work in progress may remove from the future
  // str_t 									provide_form(str_x);		// | revisit later <i may use diffirent encoding and i do am building my>
	
  len_t 			size(any_p trg){ return find(trg)->size; }
  inline void shut( any_p cur )
  {
    hdr_p  dlt = grab(cur);
    if(not dlt) return;
    memset(cur, 0, dlt->size);
		memset(dlt, 0, sizeof(hdr_t));
    junk( dlt );
  }
  
  void reset()
  {
    hdr_p ndx = nullptr;
    while(entry)
    {
      ndx   = entry;
      entry = entry->next;

      delete ndx;
    }
  }
	
//private:  future be private
  hdr_p entry{nullptr};
  hdr_p empty{nullptr};
	
	len_t scape{ 0 };
	len_t range{ 0 };
	len_t width{ 0 };
	
	#include "paradigm_head.hpp"
};

struct au::Archetype
{
	 Archetype(prd_r meta, len_t len)
	: meta(meta)
	,	scape( reinterpret_cast<len_t>(meta.to_open(len)) )
	,	range( len )
	{
	}
	
	~Archetype()
	{
		meta.shut(reinterpret_cast<any_p>(scape));
		for(hdr_p ndx = entry; ndx; ndx = ndx->next) 
			meta.junk(ndx);
	}
	
	any_p to_open(len_t demand)
	{
		if(demand == 0) return nullptr;
		
		hdr_p cur = seek(demand);
		if(not cur) return nullptr;
		
		return cur->ptr<void>();
	}
	
	template <typename ini_t>
	ini_t* to_open(len_t demand)
	{
		if(demand == 0) return nullptr;
		
		hdr_p cur = seek(demand);
		if(not cur) return nullptr;
		
		return cur->ptr<ini_t>();
	}
	
	inline x08_p ptr()						{ return reinterpret_cast<x08_p>(scape); }
	inline x08_p ptr(len_t offset){ return reinterpret_cast<x08_p>(scape + offset); }
	
//private:
	prd_r meta;
	hdr_p entry = nullptr;

	len_t scape{0};
	len_t range{0};
	
	#include "archetype_head.hpp"
};

template <typename ini_t>
struct au::Vector
{
  bool operator +=(len_t npt)
  {
    ini_t* new_vec = nullptr;
    if( data == nullptr )
    {
      new_vec = meta.to_open<ini_t>( npt );
      if(not new_vec) return false;
      
      data = new_vec;
      size = npt;
      return true;
    }
    else
    {
      new_vec = meta.co_open<ini_t>(data, sizeof(ini_t)*(size+npt));
      if(new_vec == nullptr) 
			new_vec = meta.re_open<ini_t>(data, sizeof(ini_t)*(size+npt));
			if(new_vec == nullptr) 
		  return false;
			
			data = new_vec;
      size = size + npt;
      return true;
    }
  }
  
  bool operator -=(len_t npt)
  {
    if(npt > size)
    {
      meta.shut(data);
      size = 0;
      return false;
    }
    
    ini_t* new_vec = meta.co_open<ini_t>(data, sizeof(ini_t)*(size - npt));
    if(not new_vec) 
      return false;
    
    data = new_vec;
    size -= npt;
    
    return true;
  }
	
	// | push back
	vec_t<ini_t>& operator> (ini_t target){ (*this) += 1, data[size - 1] = target; return *this; }
	ini_t*       operator>>	(ini_t target){ (*this) += 1; return &data[size - 1] = target; }
	vec_t<ini_t>& operator< (ini_t target){ (*this) += 1; data[0] = target; return *this; }
	vec_t<ini_t> operator<<	(ini_t target){ (*this) += 1; memmove(data+1, data, sizeof(ini_t)*size); data[0] = target; return *this; }
  
	ini_t* push_back(){ this->operator+=(1); return &data[size - 1]; }
	
	ini_t* vec() const { return data; }
	
  bool operator==(len_t size)
  {
    ini_t* new_vec = meta.co_open<ini_t>(data, size);
    if(not new_vec) 
      return false;
  
    return true;
  }
  
  void reset()
  {
    meta.shut(data);
    data = nullptr;
    size = 0;
  }

  len_t  len() { return size; }
	ini_t* vec() { return data; }
	ini_t& back(){ return data[size - 1]; }
  ini_t* operator * ()          { return data; }
  ini_t& operator [](len_t ndx) { return data[ndx]; }
	ini_t* operator ()(len_t ndx) { return ndx <= size ? &data[ndx] : nullptr; }
  
  ini_t* begin() const { return data; }
	ini_t* end()   const { return data + size; } 
	 
//private:
  prd_r  meta = nullptr;
  ini_t* data = nullptr;
  len_t  size = 0;
};

